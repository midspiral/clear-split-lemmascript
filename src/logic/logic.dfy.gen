// Generated by lsc from logic.ts

datatype Expense = Expense(paidBy: int, amount: int, shares: seq<int>)

datatype Settlement = Settlement(from: int, to: int, amount: int)

datatype Action = addExpense(expense: Expense) | addSettlement(settlement: Settlement)

datatype Model = Model(memberCount: nat, expenses: seq<Expense>, settlements: seq<Settlement>)

function sumTo(arr: seq<int>, n: nat): int
  requires (n <= |arr|)
{
  if (n == 0) then
    0
  else
    (sumTo(arr, (n - 1)) + arr[(n - 1)])
}

function expenseDelta(paidBy: int, amount: int, share: int, member: int): int
{
  if (paidBy == member) then
    (amount - share)
  else
    (0 - share)
}

lemma expenseDelta_ensures(paidBy: int, amount: int, share: int, member: int)
  ensures ((paidBy == member) ==> (expenseDelta(paidBy, amount, share, member) == (amount - share)))
  ensures ((paidBy != member) ==> (expenseDelta(paidBy, amount, share, member) == (0 - share)))
{
}

function settlementDelta(from: int, to: int, amount: int, member: int): int
{
  if (from == member) then
    amount
  else
    if (to == member) then
      (0 - amount)
    else
      0
}

lemma settlementDelta_ensures(from: int, to: int, amount: int, member: int)
  ensures ((from == member) ==> (settlementDelta(from, to, amount, member) == amount))
  ensures ((to == member) ==> (from != member) ==> (settlementDelta(from, to, amount, member) == (0 - amount)))
  ensures ((from != member) ==> (to != member) ==> (settlementDelta(from, to, amount, member) == 0))
{
}

function validExpense(e: Expense, memberCount: nat): bool
{
  (((((e.paidBy >= 0) && (e.paidBy < memberCount)) && (e.amount >= 0)) && (|e.shares| == memberCount)) && (sumTo(e.shares, memberCount) == e.amount))
}

function allExpensesValid(expenses: seq<Expense>, n: nat, memberCount: nat): bool
  requires (n <= |expenses|)
{
  if (n == 0) then
    true
  else
    (validExpense(expenses[(n - 1)], memberCount) && allExpensesValid(expenses, (n - 1), memberCount))
}

function validSettlement(s: Settlement, memberCount: nat): bool
{
  ((((((s.from >= 0) && (s.to >= 0)) && (s.from < memberCount)) && (s.to < memberCount)) && (s.from != s.to)) && (s.amount >= 0))
}

function allSettlementsValid(settlements: seq<Settlement>, n: nat, memberCount: nat): bool
  requires (n <= |settlements|)
{
  if (n == 0) then
    true
  else
    (validSettlement(settlements[(n - 1)], memberCount) && allSettlementsValid(settlements, (n - 1), memberCount))
}

function inv(model: Model): bool
{
  (allExpensesValid(model.expenses, |model.expenses|, model.memberCount) && allSettlementsValid(model.settlements, |model.settlements|, model.memberCount))
}

function step(model: Model, action: Action): Model
  requires inv(model)
{
  match action {
    case addExpense(i_action_expense) =>
      var e := i_action_expense;
      if (e.paidBy < 0) then
        model
      else
        if (e.paidBy >= model.memberCount) then
          model
        else
          if (e.amount < 0) then
            model
          else
            if (|e.shares| != model.memberCount) then
              model
            else
              if (sumTo(e.shares, model.memberCount) != e.amount) then
                model
              else
                Model(model.memberCount, (model.expenses + [e]), model.settlements)
    case addSettlement(i_action_settlement) =>
      var s := i_action_settlement;
      if (s.from < 0) then
        model
      else
        if (s.to < 0) then
          model
        else
          if (s.from >= model.memberCount) then
            model
          else
            if (s.to >= model.memberCount) then
              model
            else
              if (s.from == s.to) then
                model
              else
                if (s.amount < 0) then
                  model
                else
                  Model(model.memberCount, model.expenses, (model.settlements + [s]))
  }
}

lemma step_ensures(model: Model, action: Action)
  requires inv(model)
  ensures inv(step(model, action))
{
}

method computeBalance(paidBy: seq<int>, amounts: seq<int>, shares: seq<int>, settFrom: seq<int>, settTo: seq<int>, settAmounts: seq<int>, member: nat, expenseCount: nat, settlementCount: nat) returns (res: int)
  requires (expenseCount <= |paidBy|)
  requires (expenseCount <= |amounts|)
  requires (expenseCount <= |shares|)
  requires (settlementCount <= |settFrom|)
  requires (settlementCount <= |settTo|)
  requires (settlementCount <= |settAmounts|)
{
  var balance := 0;
  var i := 0;
  while (i < expenseCount)
    invariant (i <= expenseCount)
    decreases (expenseCount - i)
  {
    var i_t0 := expenseDelta(paidBy[i], amounts[i], shares[i], member);
    balance := (balance + i_t0);
    i := (i + 1);
  }
  var j := 0;
  while (j < settlementCount)
    invariant (j <= settlementCount)
    decreases (settlementCount - j)
  {
    var i_t1 := settlementDelta(settFrom[j], settTo[j], settAmounts[j], member);
    balance := (balance + i_t1);
    j := (j + 1);
  }
  return balance;
}
